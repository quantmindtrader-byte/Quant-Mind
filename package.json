{
  "name": "quantmind-desktop",
  "version": "1.2.3",
  "description": "QuantMind Desktop Trading Application",
  "author": "QuantMind",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron src/main/main.js",
    "dev:bridge": "python src/bridge/mt5_bridge.py 8080",
    "dev:nginx": "node scripts/start-nginx.js",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "start": "electron src/main/main.js",
    "start:dev": "electron src/main/main.js"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^7.6.0",
    "wait-on": "^7.0.1",
    "electron": "^22.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24"
  },
  "dependencies": {
    "socket.io-client": "^4.7.2",
    "node-fetch": "^2.6.7"
  },
  "build": {
    "appId": "com.quantmind.desktop",
    "productName": "QuantMind Desktop",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "src/bot/**/*"
    ],

    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "QuantMind Desktop",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}