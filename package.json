{
  "name": "quantmind-desktop",
  "version": "1.0.5",
  "description": "QuantMind Trading Desktop Application",
  "author": "QuantMind",
  "main": "src/main/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/quantmindtrader-byte/Quant-Mind.git"
  },
  "scripts": {
    "start": "electron src/main/main.js",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "electron src/main/main.js",
    "build": "npm run build:renderer && electron-builder",
    "dist": "npm run build:renderer && electron-builder",
    "publish": "npm run build:renderer && electron-builder --publish=always",
    "release": "npm run build:renderer && electron-builder --publish=always",
    "build:renderer": "vite build",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.1.7",
    "express": "^4.21.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.quantmind.desktop",
    "productName": "QuantMind Desktop",
    "copyright": "Copyright © 2024 QuantMind",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "dist-renderer/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "publisherName": "QuantMind"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "forceCodeSigning": false,
    "publish": {
      "provider": "github",
      "owner": "quantmindtrader-byte",
      "repo": "Quant-Mind"
    }
  }
}
